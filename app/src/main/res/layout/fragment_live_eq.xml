<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Live EQ"
                android:textAppearance="?attr/textAppearanceHeadlineSmall" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/live_eq_add"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add band" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/live_eq_close"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Close" />
        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:scrollbars="none">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/live_eq_band_group"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:selectionRequired="true"
                app:singleLine="true"
                app:singleSelection="true" />
        </HorizontalScrollView>

        <app.siphondsp.view.ParametricEqSurface
            android:id="@+id/live_eq_surface"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="12dp" />

        <TextView
            android:id="@+id/live_eq_frequency_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Frequency: 1000 Hz"
            android:textAppearance="?attr/textAppearanceTitleMedium" />

        <SeekBar
            android:id="@+id/live_eq_frequency"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="1000" />

        <TextView
            android:id="@+id/live_eq_gain_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Gain: 0.0 dB"
            android:textAppearance="?attr/textAppearanceTitleMedium" />

        <SeekBar
            android:id="@+id/live_eq_gain"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="600" />

        <TextView
            android:id="@+id/live_eq_q_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Q: 1.41"
            android:textAppearance="?attr/textAppearanceTitleMedium" />

        <SeekBar
            android:id="@+id/live_eq_q"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="1000" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Filter type"
            android:textAppearance="?attr/textAppearanceLabelLarge" />

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/live_eq_filter_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:selectionRequired="true"
            app:singleSelection="true">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/live_eq_filter_peaking"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Peaking" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/live_eq_filter_low_shelf"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Low shelf" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/live_eq_filter_high_shelf"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="High shelf" />
        </com.google.android.material.button.MaterialButtonToggleGroup>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Channel"
            android:textAppearance="?attr/textAppearanceLabelLarge" />

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/live_eq_channel_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:selectionRequired="true"
            app:singleSelection="true">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/live_eq_channel_both"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Both" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/live_eq_channel_left"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Left" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/live_eq_channel_right"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Right" />
        </com.google.android.material.button.MaterialButtonToggleGroup>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
